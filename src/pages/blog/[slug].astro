---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import TagBadge from '../../components/blog/TagBadge.astro';
import ShareLinks from '../../components/blog/ShareLinks.astro';
import { formatDate } from '../../data/blog-schema';

export async function getStaticPaths() {
  const articles = await getCollection('blog');
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const siteUrl = 'https://rotative.com.ar';
const articleUrl = `${siteUrl}/blog/${article.id}`;
const ogImage = article.data.heroImage || `${siteUrl}/og-image.png`;
---

<Base
  title={`${article.data.title} | Blog Rotative`}
  description={article.data.description}
  ogTitle={article.data.title}
  ogImage={ogImage}
>
  <article class="py-12 sm:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">

      <header data-animate>
        <a
          href="/blog"
          class="inline-flex items-center gap-1.5 text-sm text-corporate-400 dark:text-corporate-500 hover:text-accent-500 dark:hover:text-accent-400 transition-colors mb-8"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6"/>
          </svg>
          Volver al blog
        </a>

        {article.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-4">
            {article.data.tags.map((tag) => <TagBadge tag={tag} />)}
          </div>
        )}

        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-corporate-900 dark:text-corporate-50 leading-tight">
          {article.data.title}
        </h1>

        <p class="mt-4 text-lg text-corporate-600 dark:text-corporate-300">
          {article.data.description}
        </p>

        <div class="mt-6 flex flex-wrap items-center gap-4 text-sm text-corporate-400 dark:text-corporate-500">
          <time datetime={article.data.pubDate.toISOString()}>
            Publicado el {formatDate(article.data.pubDate)}
          </time>
          {article.data.updated_at && (
            <>
              <span aria-hidden="true">·</span>
              <time datetime={article.data.updated_at.toISOString()}>
                Actualizado el {formatDate(article.data.updated_at)}
              </time>
            </>
          )}
        </div>

        <div class="mt-4">
          <ShareLinks url={articleUrl} title={article.data.title} />
        </div>
      </header>

      {article.data.heroImage && (
        <div data-animate class="mt-8 rounded-xl overflow-hidden">
          <img
            src={article.data.heroImage}
            alt={article.data.title}
            class="w-full h-auto"
            loading="eager"
          />
        </div>
      )}

      <div class="mt-10 blog-content">
        <Content />
      </div>

      {article.data.linkedinUrl && (
        <div data-animate class="mt-12 p-6 rounded-xl border border-corporate-200 dark:border-corporate-700 bg-corporate-50 dark:bg-corporate-800/50">
          <p class="text-sm text-corporate-600 dark:text-corporate-300 mb-3">
            Este artículo también está publicado en LinkedIn.
          </p>
          <a
            href={article.data.linkedinUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-semibold text-accent-500 hover:text-accent-600 dark:hover:text-accent-400 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            Ver publicación en LinkedIn
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17 17 7"/>
              <path d="M7 7h10v10"/>
            </svg>
          </a>
        </div>
      )}

      <footer data-animate class="mt-12 pt-8 border-t border-corporate-100 dark:border-corporate-800">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <a
            href="/blog"
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent-500 hover:text-accent-600 dark:hover:text-accent-400 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m15 18-6-6 6-6"/>
            </svg>
            Volver al blog
          </a>
          <ShareLinks url={articleUrl} title={article.data.title} />
        </div>
      </footer>
    </div>
  </article>

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: article.data.title,
      description: article.data.description,
      image: ogImage,
      datePublished: article.data.pubDate.toISOString(),
      dateModified: article.data.updated_at
        ? article.data.updated_at.toISOString()
        : article.data.pubDate.toISOString(),
      url: articleUrl,
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': articleUrl,
      },
      author: {
        '@type': 'Organization',
        name: 'Rotative',
        url: siteUrl,
      },
      publisher: {
        '@type': 'Organization',
        name: 'Rotative',
        url: siteUrl,
        logo: {
          '@type': 'ImageObject',
          url: `${siteUrl}/logo.webp`,
        },
      },
    })}
  />
</Base>
