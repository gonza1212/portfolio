---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary';
  target?: string;
  rel?: string;
}

const { href, variant = 'primary', target, rel } = Astro.props;

const classes = {
  primary: 'bg-accent-500 hover:bg-accent-600 text-white font-semibold py-3 px-6 rounded-lg transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg inline-block',
  secondary: 'border border-corporate-300 dark:border-corporate-600 text-corporate-900 dark:text-corporate-50 hover:bg-corporate-100 dark:hover:bg-corporate-800 font-semibold py-3 px-6 rounded-lg transition-all duration-300 hover:-translate-y-0.5 inline-block',
};
---
<a href={href} target={target} rel={rel} class={classes[variant]}>
  <slot />
</a>
