---
const year = new Date().getFullYear();
---

<footer class="bg-corporate-900 dark:bg-corporate-950 text-corporate-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div>
        <p class="font-bold text-lg text-white">Rotative</p>
        <p class="text-sm text-corporate-400 mt-1">Software empresarial a medida</p>
      </div>
      <div class="text-sm text-corporate-400">
        <a href="mailto:contacto@rotative.com.ar" class="hover:text-accent-400 transition-colors">
          contacto@rotative.com.ar
        </a>
      </div>
    </div>
    <div class="border-t border-corporate-800 mt-8 pt-6 text-xs text-corporate-600">
      &copy; {year} Rotative. Todos los derechos reservados.
    </div>
  </div>
</footer>
