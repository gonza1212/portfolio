---
import SectionTitle from '../ui/SectionTitle.astro';
import { demos } from '../../data/demos.ts';
---

<section id="demos" class="py-20 bg-corporate-50 dark:bg-corporate-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <SectionTitle
      title="Casos de uso hipotéticos"
      subtitle="Situaciones reales de la industria que resolvemos con tecnología simple y efectiva"
      centered
    />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
      {demos.map((demo, i) => (
        <div
          data-animate
          style={`transition-delay:${i * 150}ms`}
          class="bg-white dark:bg-corporate-800 border border-corporate-100 dark:border-corporate-700 rounded-xl p-8 flex flex-col hover:border-accent-500 dark:hover:border-accent-500 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-lg"
        >
          <div class="text-4xl mb-4">{demo.icon}</div>
          <p class="text-xs font-semibold text-accent-500 uppercase tracking-wider mb-2">
            {demo.scenario}
          </p>
          <p class="text-sm text-corporate-600 dark:text-corporate-300 leading-relaxed mb-8 flex-1">
            {demo.problem}
          </p>
          <a
            href={demo.href}
            class="inline-block w-full text-center bg-accent-500 hover:bg-accent-600 text-white font-semibold py-3 px-6 rounded-lg transition-colors text-sm"
          >
            {demo.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
