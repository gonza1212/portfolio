---
const WEB3FORMS_KEY = 'd7de0e2b-175b-4ce6-827d-5d053163b554';

const inputClasses = "w-full bg-white dark:bg-corporate-800 border border-corporate-200 dark:border-corporate-700 rounded-lg px-4 py-3 text-corporate-900 dark:text-corporate-50 placeholder-corporate-400 dark:placeholder-corporate-600 focus:outline-none focus:ring-2 focus:ring-accent-500 transition-colors";
---

<section id="contacto" class="py-20 bg-corporate-50 dark:bg-corporate-950">
  <div class="max-w-xl mx-auto px-4 sm:px-6">
    <div data-animate class="text-center mb-10">
      <h2 class="text-3xl font-bold text-corporate-900 dark:text-corporate-50">
        Hablemos de tu proyecto
      </h2>
      <p class="text-lg text-corporate-600 dark:text-corporate-300 mt-3">
        Contanos qué necesitás y te respondemos en menos de 24 horas
      </p>
    </div>

    <form id="contact-form" data-animate class="space-y-5">
      <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
      <input type="hidden" name="subject" value="Nuevo contacto desde el sitio web" />
      <input type="hidden" name="from_name" value="Sitio Web Rotative" />
      <input type="hidden" name="email" value="contacto@rotative.com.ar" />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

      <div>
        <label for="name" class="block text-sm font-medium text-corporate-700 dark:text-corporate-300 mb-1.5">
          Nombre *
        </label>
        <input type="text" id="name" name="name" required placeholder="Tu nombre" class={inputClasses} />
      </div>

      <div>
        <label for="company" class="block text-sm font-medium text-corporate-700 dark:text-corporate-300 mb-1.5">
          Empresa *
        </label>
        <input type="text" id="company" name="company" required placeholder="Nombre de tu empresa" class={inputClasses} />
      </div>

      <div>
        <label for="phone" class="block text-sm font-medium text-corporate-700 dark:text-corporate-300 mb-1.5">
          Teléfono <span class="text-corporate-400">(opcional)</span>
        </label>
        <input type="tel" id="phone" name="phone" placeholder="+54 9 11 0000-0000" class={inputClasses} />
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-corporate-700 dark:text-corporate-300 mb-1.5">
          Mensaje *
        </label>
        <textarea
          id="message"
          name="message"
          required
          rows="4"
          placeholder="Contanos brevemente qué necesitás gestionar o automatizar"
          class={inputClasses}
        ></textarea>
      </div>

      <button
        id="submit-btn"
        type="submit"
        class="w-full bg-accent-500 hover:bg-accent-600 text-white font-semibold py-3 px-6 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Enviar mensaje
      </button>
    </form>

    <!-- Modal de éxito -->
    <div id="success-modal" class="fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-all duration-300">
      <div id="success-modal-card" class="bg-white dark:bg-corporate-800 rounded-xl p-8 max-w-md w-full text-center shadow-2xl scale-95 transition-all duration-300">
        <div class="text-4xl mb-4">✅</div>
        <h3 class="font-semibold text-xl text-corporate-900 dark:text-corporate-50 mb-2">
          ¡Mensaje enviado!
        </h3>
        <p class="text-corporate-600 dark:text-corporate-300 mb-6">
          Recibimos tu consulta. Te respondemos en menos de 24 horas.
        </p>
        <button
          id="close-modal"
          class="bg-accent-500 hover:bg-accent-600 text-white font-semibold py-2 px-6 rounded-lg transition-colors"
        >
          Cerrar
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    const form = document.getElementById('contact-form');
    const modal = document.getElementById('success-modal');
    const card = document.getElementById('success-modal-card');
    const submitBtn = document.getElementById('submit-btn');
    const closeBtn = document.getElementById('close-modal');

    if (!form) return;

    function showModal() {
      modal.classList.remove('opacity-0', 'pointer-events-none');
      modal.classList.add('opacity-100', 'pointer-events-auto');
      card.classList.remove('scale-95');
      card.classList.add('scale-100');
      document.body.style.overflow = 'hidden';
    }

    function hideModal() {
      modal.classList.remove('opacity-100', 'pointer-events-auto');
      modal.classList.add('opacity-0', 'pointer-events-none');
      card.classList.remove('scale-100');
      card.classList.add('scale-95');
      document.body.style.overflow = '';
    }

    form.addEventListener('submit', async function(e) {
      e.preventDefault();

      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando...';

      const formData = new FormData(form);
      const object = Object.fromEntries(formData);
      const json = JSON.stringify(object);

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: json
        });

        const result = await response.json();

        if (response.status === 200) {
          form.reset();
          showModal();
        } else {
          alert(result.message || 'Error al enviar el mensaje. Intentá de nuevo.');
        }
      } catch (error) {
        alert('Error de conexión. Verificá tu internet e intentá de nuevo.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enviar mensaje';
      }
    });

    closeBtn.addEventListener('click', hideModal);

    modal.addEventListener('click', function(e) {
      if (e.target === modal) {
        hideModal();
      }
    });
  })();
</script>

