---
import SectionTitle from '../ui/SectionTitle.astro';

const differentials = [
  {
    icon: '🔏',
    title: 'Confidencialidad garantizada',
    description: 'Firmamos NDA antes de empezar. Cada cliente tiene su propia base de datos, sin datos compartidos entre empresas.',
  },
  {
    icon: '⚡',
    title: 'Entregas rápidas',
    description: 'Software funcionando en 30 días. Iteramos cada 15 con feedback directo. Sin meses de análisis antes de ver resultados.',
  },
  {
    icon: '💰',
    title: 'Costo accesible',
    description: 'Sin estructura grande ni procesos burocráticos. Nuestro modelo de trabajo nos permite ofrecer precios significativamente menores que las grandes consultoras.',
  },
  {
    icon: '📋',
    title: 'SLA definido',
    description: 'Los tiempos de respuesta y los compromisos de soporte quedan en el contrato desde el inicio. Sin sorpresas.',
  },
    {
      icon: '🏭',
      title: 'Especialistas en industria',
      description: 'Entendemos los flujos de trabajo empresariales. El software que desarrollamos responde a la operación real de tu empresa.',
    },
];
---

<section id="nosotros" class="py-20 bg-corporate-50 dark:bg-corporate-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <div>
        <SectionTitle
          title="Por qué elegirnos"
          subtitle="Trabajamos diferente a las grandes consultoras. Más ágiles, más directos, más accesibles."
        />
        <p class="mt-6 text-sm text-corporate-600 dark:text-corporate-300 leading-relaxed">
          Desarrollamos software a medida para empresas que todavía gestionan su operación con Excel, papeles o sistemas desactualizados. Sistemas web de gestión empresarial, apps móviles con modo offline e integración con ERP o software de facturación existente.
        </p>
        <p class="mt-4 text-sm text-corporate-600 dark:text-corporate-300 leading-relaxed">
          Tenemos un caso en producción ininterrumpida desde 2019 en una empresa gráfica, donde reemplazamos un proceso de cotización dependiente de una sola persona por un sistema accesible para todo el equipo.
        </p>
        <div class="mt-6">
          <a
            href="https://www.linkedin.com/company/rotative/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-accent-500 hover:text-accent-600 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            Seguinos en LinkedIn
          </a>
        </div>
      </div>
      <div class="space-y-6">
        {differentials.map((item, i) => (
          <div data-animate class="flex gap-4" style={`transition-delay:${i * 100}ms`}>
            <div class="text-2xl flex-shrink-0 mt-0.5">{item.icon}</div>
            <div>
              <h3 class="font-semibold text-corporate-900 dark:text-corporate-50 mb-1">
                {item.title}
              </h3>
              <p class="text-sm text-corporate-600 dark:text-corporate-300 leading-relaxed">
                {item.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
