---
import TagBadge from './TagBadge.astro';
import { formatDate } from '../../data/blog-schema';

interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  heroImage?: string;
  tags: string[];
}

const { slug, title, description, pubDate, heroImage, tags } = Astro.props;
---

<a
  href={`/blog/${slug}`}
  class="group block bg-white dark:bg-corporate-900 overflow-hidden hover:shadow-lg hover:border-accent-500/30 dark:hover:border-accent-500/30 transition-all duration-300"
>
  {heroImage && (
    <div class="aspect-[16/9] overflow-hidden">
      <img
        src={heroImage}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </div>
  )}
  <div class="p-1 sm:p-2">
    <time
      datetime={pubDate.toISOString()}
      class="text-xs text-corporate-400 dark:text-corporate-500"
    >
      {formatDate(pubDate)}
    </time>
    <h3 class="mt-2 text-lg font-semibold text-corporate-900 dark:text-corporate-50 group-hover:text-accent-500 dark:group-hover:text-accent-400 transition-colors line-clamp-2">
      {title}
    </h3>
    <p class="mt-2 text-sm text-corporate-600 dark:text-corporate-300 line-clamp-2">
      {description}
    </p>
    {tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {tags.map((tag) => <TagBadge tag={tag} />)}
      </div>
    )}
  </div>
</a>
