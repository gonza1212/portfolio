---
import { slugifyTag } from '../../data/blog-schema';

interface Props {
  tag: string;
  linked?: boolean;
}

const { tag, linked = true } = Astro.props;
const tagSlug = slugifyTag(tag);
---

{linked ? (
  <a
    href={`/blog/tag/${tagSlug}`}
    class="inline-block text-xs font-medium px-2.5 py-1 rounded-full bg-corporate-100 dark:bg-corporate-800 text-corporate-600 dark:text-corporate-300 hover:bg-accent-500 hover:text-white dark:hover:bg-accent-500 dark:hover:text-white transition-colors"
  >
    {tag}
  </a>
) : (
  <span class="inline-block text-xs font-medium px-2.5 py-1 rounded-full bg-corporate-100 dark:bg-corporate-800 text-corporate-600 dark:text-corporate-300">
    {tag}
  </span>
)}
